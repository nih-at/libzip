{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "test sandbox",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/regress/ziptool_regress",
            "args": [
                "--",
                "testfile.zip",
                "add_from_zip",
                "abac-repeat.txt",
                "testdeflated.zzip",
                "0",
                "0",
                "-1",
                "zin_close",
                "0"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/regress/sandbox",
            "environment": [],
            "externalConsole": false,
            "console": "integratedTerminal",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "test ext4fs",
            "type": "cppdbg",
            "request": "launch",
            "program": "/mnt/build/regress/ziptool_regress",
            "args": [
                "--",
                "testcomment.zip",
                "set_archive_comment",
                ""
            ],
            "stopAtEntry": false,
            "cwd": "/mnt/build/regress/sandbox",
            "environment": [],
            "externalConsole": false,
            "console": "integratedTerminal",
            "MIMode": "gdb",
            "stopAtEntry": true,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}